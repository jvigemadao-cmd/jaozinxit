<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Menoxit</title>

<style>
body {
  margin: 0;
  background: black;
  color: #00fff7;
  font-family: Arial;
  overflow: hidden;
}

/* Painel */
.panel {
  position: absolute;
  top: 50px;
  left: 20px;
  width: 260px;
  padding: 15px;
  border: 2px solid #00fff7;
  box-shadow: 0 0 20px #00fff7;
  background: rgba(0,0,0,0.7);
  animation: glow 2s infinite alternate;
}

@keyframes glow {
  from { box-shadow: 0 0 10px #00fff7; }
  to { box-shadow: 0 0 25px #00fff7; }
}

h2 {
  text-align: center;
}

/* Botões */
.toggle {
  display: flex;
  justify-content: space-between;
  margin: 10px 0;
}

/* Slider */
.slider {
  width: 100%;
}

/* Mira */
.crosshair {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 30px;
  height: 30px;
  transform: translate(-50%, -50%);
}

.crosshair::before,
.crosshair::after {
  content: "";
  position: absolute;
  background: #00fff7;
}

.crosshair::before {
  width: 2px;
  height: 30px;
  left: 14px;
}

.crosshair::after {
  width: 30px;
  height: 2px;
  top: 14px;
}

/* efeito ativo */
.active {
  color: #00ff00;
}
</style>
</head>

<body>

<div class="panel">
  <h2>Menoxit</h2>

  <div class="toggle">
    <span>Aimbot</span>
    <input type="checkbox" id="aimbot">
  </div>

  <div class="toggle">
    <span>ESP</span>
    <input type="checkbox" id="esp">
  </div>

  <div>
    Aim FOV
    <input type="range" min="10" max="100" value="30" class="slider" id="fov">
  </div>

  <div class="toggle">
    <span>No Recoil</span>
    <input type="checkbox" id="recoil">
  </div>

  <div class="toggle">
    <span>Aim Lock</span>
    <input type="checkbox" id="lock">
  </div>

</div>

<div class="crosshair" id="crosshair"></div>

<script>
const crosshair = document.getElementById("crosshair");
const fov = document.getElementById("fov");

// muda tamanho da mira
fov.addEventListener("input", () => {
  let size = fov.value;
  crosshair.style.width = size + "px";
  crosshair.style.height = size + "px";
});

// animação quando ativa botão
document.querySelectorAll("input[type=checkbox]").forEach(box => {
  box.addEventListener("change", () => {
    if(box.checked){
      box.parentElement.classList.add("active");
    } else {
      box.parentElement.classList.remove("active");
    }
  });
});

// efeito de seguir o dedo (treino)
document.addEventListener("touchmove", (e) => {
  let x = e.touches[0].clientX;
  let y = e.touches[0].clientY;
  crosshair.style.left = x + "px";
  crosshair.style.top = y + "px";
});
</script>

</body>
</html>
